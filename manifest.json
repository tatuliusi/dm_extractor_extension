{
  "manifest_version": 3,
  "name": "DM Extractor — Meta Business Suite Batch Downloader",
  "version": "1.0.0",
  "description": "Batch-downloads all conversations from Meta Business Suite inboxes (Messenger, Instagram, WhatsApp) with date-range filtering.",
  "content_scripts": [
    {
      "matches": [
        "https://business.facebook.com/*",
        "https://*.facebook.com/latest/inbox/*"
      ],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.css"],
      "matches": ["https://*.facebook.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
